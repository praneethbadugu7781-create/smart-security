# ============================================
# Environment Configuration
# Smart Main Gate Entry-Exit System
# ============================================
# Copy this file to .env and update values

# Server Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=college_security

# Session Configuration (generate secure random string)
SESSION_SECRET=your-super-secret-session-key-change-this-in-production

# File Upload Configuration
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# Security Configuration
BCRYPT_ROUNDS=12

# College Timing Configuration (HH:MM format)
COLLEGE_START_TIME=08:30
COLLEGE_END_TIME=17:00
LUNCH_START_TIME=12:30
LUNCH_END_TIME=13:30
HOSTEL_CURFEW_TIME=21:00

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100
