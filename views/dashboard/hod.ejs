<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body class="dashboard-page hod-dashboard">
    <!-- Sidebar Navigation -->
    <nav class="sidebar">
        <div class="sidebar-header">
            <div class="logo">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                </svg>
            </div>
            <span class="logo-text">Security System</span>
        </div>
        
        <div class="department-badge">
            <span><%= departmentName %></span>
        </div>
        
        <div class="nav-section">
            <a href="/dashboard/hod" class="nav-item active">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="3" width="7" height="9"/>
                    <rect x="14" y="3" width="7" height="5"/>
                    <rect x="14" y="12" width="7" height="9"/>
                    <rect x="3" y="16" width="7" height="5"/>
                </svg>
                <span>Dashboard</span>
            </a>
            <a href="#" class="nav-item" onclick="showSection('roaming')">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="12" y1="8" x2="12" y2="12"/>
                    <line x1="12" y1="16" x2="12.01" y2="16"/>
                </svg>
                <span>Roaming Alerts</span>
                <% if (roamingIncidents && roamingIncidents.length > 0) { %>
                    <span class="nav-badge"><%= roamingIncidents.length %></span>
                <% } %>
            </a>
            <a href="#" class="nav-item" onclick="showSection('permissions')">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                    <polyline points="14 2 14 8 20 8"/>
                </svg>
                <span>Permissions</span>
            </a>
            <a href="#" class="nav-item" onclick="showSection('students')">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                    <circle cx="9" cy="7" r="4"/>
                </svg>
                <span>My Students</span>
            </a>
        </div>
        
        <div class="sidebar-footer">
            <div class="user-info">
                <div class="user-avatar"><%= user.full_name.charAt(0) %></div>
                <div class="user-details">
                    <span class="user-name"><%= user.full_name %></span>
                    <span class="user-role">HOD</span>
                </div>
            </div>
            <a href="/logout" class="logout-link">Logout</a>
        </div>
    </nav>
    
    <!-- Main Content -->
    <main class="main-content">
        <!-- Header -->
        <header class="content-header">
            <div class="header-title">
                <h1>HOD Dashboard</h1>
                <p class="header-subtitle"><%= departmentName %></p>
            </div>
            <div class="header-actions">
                <div class="alert-bell" id="alertBell" onclick="showAlerts()">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                        <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                    </svg>
                    <span class="alert-count" id="alertCount"><%= unreadAlertCount %></span>
                </div>
            </div>
        </header>
        
        <!-- Stats Cards -->
        <section class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon entries">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="10 17 15 12 10 7"/>
                    </svg>
                </div>
                <div class="stat-content">
                    <span class="stat-value"><%= stats.total_entries || 0 %></span>
                    <span class="stat-label">Student Entries</span>
                </div>
            </div>
            
            <div class="stat-card">
                <div class="stat-icon exits">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="14 7 9 12 14 17"/>
                    </svg>
                </div>
                <div class="stat-content">
                    <span class="stat-value"><%= stats.total_exits || 0 %></span>
                    <span class="stat-label">Student Exits</span>
                </div>
            </div>
            
            <div class="stat-card danger">
                <div class="stat-icon roaming">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/>
                        <line x1="12" y1="8" x2="12" y2="12"/>
                    </svg>
                </div>
                <div class="stat-content">
                    <span class="stat-value"><%= roamingIncidents ? roamingIncidents.length : 0 %></span>
                    <span class="stat-label">Roaming Incidents</span>
                </div>
            </div>
            
            <div class="stat-card warning">
                <div class="stat-icon late">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/>
                        <polyline points="12 6 12 12 16 14"/>
                    </svg>
                </div>
                <div class="stat-content">
                    <span class="stat-value"><%= stats.late_entries || 0 %></span>
                    <span class="stat-label">Late Entries</span>
                </div>
            </div>
        </section>
        
        <!-- Main Grid -->
        <div class="dashboard-grid">
            <!-- Roaming Incidents (Priority) -->
            <section class="card roaming-card priority-card">
                <div class="card-header">
                    <h2>Roaming Incidents</h2>
                    <span class="badge danger"><%= roamingIncidents ? roamingIncidents.length : 0 %> Active</span>
                </div>
                <div class="card-content">
                    <div class="roaming-list" id="roamingList">
                        <% if (roamingIncidents && roamingIncidents.length > 0) { %>
                            <% roamingIncidents.forEach(incident => { %>
                                <div class="roaming-item" data-id="<%= incident.id %>">
                                    <div class="roaming-student">
                                        <strong><%= incident.full_name %></strong>
                                        <span><%= incident.roll_number %> • Year <%= incident.year_of_study %><%= incident.section ? ' ' + incident.section : '' %></span>
                                    </div>
                                    <div class="roaming-time">
                                        <span>Detected at <%= new Date(incident.detected_at).toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit' }) %></span>
                                    </div>
                                    <div class="roaming-actions">
                                        <button class="btn-resolve" onclick="resolveRoaming('<%= incident.id %>')">Resolve</button>
                                    </div>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <div class="empty-state success">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                                    <polyline points="22 4 12 14.01 9 11.01"/>
                                </svg>
                                <p>No roaming incidents</p>
                            </div>
                        <% } %>
                    </div>
                </div>
            </section>
            
            <!-- Live Feed -->
            <section class="card live-feed-card">
                <div class="card-header">
                    <h2>Department Activity</h2>
                    <span class="refresh-indicator">
                        <span class="pulse"></span>
                        Live
                    </span>
                </div>
                <div class="card-content">
                    <div class="activity-list" id="activityList">
                        <% if (recentLogs && recentLogs.length > 0) { %>
                            <% recentLogs.slice(0, 15).forEach(log => { %>
                                <div class="activity-item <%= log.event_type %> <%= log.is_allowed ? '' : 'denied' %>">
                                    <div class="activity-icon">
                                        <% if (log.event_type === 'entry') { %>
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <polyline points="10 17 15 12 10 7"/>
                                            </svg>
                                        <% } else if (log.event_type === 'exit') { %>
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <polyline points="14 7 9 12 14 17"/>
                                            </svg>
                                        <% } else { %>
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <circle cx="12" cy="12" r="10"/>
                                            </svg>
                                        <% } %>
                                    </div>
                                    <div class="activity-details">
                                        <span class="activity-name"><%= log.full_name %></span>
                                        <span class="activity-info"><%= log.roll_number %></span>
                                    </div>
                                    <div class="activity-meta">
                                        <span class="activity-type"><%= log.event_type.toUpperCase() %></span>
                                        <span class="activity-time"><%= new Date(log.event_timestamp).toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit' }) %></span>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <div class="empty-state">
                                <p>No activity yet today</p>
                            </div>
                        <% } %>
                    </div>
                </div>
            </section>
            
            <!-- Pending Permission Verifications -->
            <section class="card permissions-card">
                <div class="card-header">
                    <h2>Permission Letters</h2>
                    <span class="badge"><%= pendingPermissions ? pendingPermissions.length : 0 %> Pending</span>
                </div>
                <div class="card-content">
                    <div class="permissions-list" id="permissionsList">
                        <% if (pendingPermissions && pendingPermissions.length > 0) { %>
                            <% pendingPermissions.forEach(permission => { %>
                                <div class="permission-item" data-id="<%= permission.id %>">
                                    <div class="permission-info">
                                        <strong><%= permission.full_name %></strong>
                                        <span><%= permission.roll_number %></span>
                                        <span class="permission-reason"><%= permission.reason %></span>
                                    </div>
                                    <div class="permission-actions">
                                        <a href="/uploads/permission_letters/<%= permission.photo_filename %>" target="_blank" class="btn-view">View</a>
                                        <button class="btn-verify" onclick="verifyPermission('<%= permission.id %>')">Verify</button>
                                    </div>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <div class="empty-state">
                                <p>No pending verifications</p>
                            </div>
                        <% } %>
                    </div>
                </div>
            </section>
        </div>
    </main>
    
    <!-- Resolve Modal -->
    <div class="modal" id="resolveModal" style="display: none;">
        <div class="modal-content">
            <h3>Resolve Roaming Incident</h3>
            <textarea id="resolveNotes" placeholder="Add notes about the resolution..."></textarea>
            <div class="modal-actions">
                <button onclick="confirmResolve()" class="btn-primary">Resolve</button>
                <button onclick="closeModal()" class="btn-secondary">Cancel</button>
            </div>
        </div>
    </div>
    
    <script src="/js/dashboard.js"></script>
    <script>
        let currentRoamingId = null;
        
        function resolveRoaming(id) {
            currentRoamingId = id;
            document.getElementById('resolveModal').style.display = 'flex';
        }
        
        function closeModal() {
            document.getElementById('resolveModal').style.display = 'none';
            currentRoamingId = null;
        }
        
        async function confirmResolve() {
            if (!currentRoamingId) return;
            
            const notes = document.getElementById('resolveNotes').value;
            
            try {
                const response = await fetch(`/api/roaming/${currentRoamingId}/resolve`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ notes })
                });
                
                const data = await response.json();
                
                if (data.success) {
                    document.querySelector(`.roaming-item[data-id="${currentRoamingId}"]`).remove();
                    closeModal();
                }
            } catch (error) {
                console.error('Error resolving:', error);
            }
        }
        
        async function verifyPermission(id) {
            try {
                const response = await fetch(`/api/permissions/${id}/verify`, {
                    method: 'POST'
                });
                
                const data = await response.json();
                
                if (data.success) {
                    document.querySelector(`.permission-item[data-id="${id}"]`).remove();
                }
            } catch (error) {
                console.error('Error verifying:', error);
            }
        }
        
        // Start auto-refresh
        startDashboardRefresh();
    </script>
</body>
</html>
