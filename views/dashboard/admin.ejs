<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="/css/dashboard.css">
    <style>
        /* Section Styles */
        .section-content { display: none; }
        .section-content.active { display: block; }
        
        /* Data Table Styles */
        .data-table-wrapper {
            background: var(--bg-card);
            border-radius: var(--radius-lg);
            border: 1px solid var(--border-color);
            overflow: hidden;
        }
        .table-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 16px 20px;
            border-bottom: 1px solid var(--border-color);
        }
        .table-header h2 { font-size: 1.1rem; }
        .search-box {
            display: flex;
            align-items: center;
            gap: 8px;
            background: var(--bg-hover);
            padding: 8px 14px;
            border-radius: 8px;
        }
        .search-box input {
            background: transparent;
            border: none;
            color: var(--text-primary);
            outline: none;
            width: 200px;
        }
        .search-box svg { width: 16px; height: 16px; color: var(--text-muted); }
        
        .data-table {
            width: 100%;
            border-collapse: collapse;
        }
        .data-table th, .data-table td {
            padding: 12px 16px;
            text-align: left;
            border-bottom: 1px solid var(--border-color);
        }
        .data-table th {
            background: var(--bg-secondary);
            font-weight: 600;
            font-size: 0.75rem;
            text-transform: uppercase;
            color: var(--text-muted);
        }
        .data-table tr:hover { background: var(--bg-hover); }
        .data-table td { font-size: 0.9rem; }
        
        .badge {
            display: inline-block;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 0.7rem;
            font-weight: 600;
        }
        .badge-success { background: rgba(16, 185, 129, 0.15); color: #10b981; }
        .badge-warning { background: rgba(245, 158, 11, 0.15); color: #f59e0b; }
        .badge-danger { background: rgba(239, 68, 68, 0.15); color: #ef4444; }
        .badge-info { background: rgba(59, 130, 246, 0.15); color: #3b82f6; }
        
        .btn {
            padding: 8px 16px;
            border: none;
            border-radius: 6px;
            font-size: 0.85rem;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
        }
        .btn-primary { background: var(--color-primary); color: white; }
        .btn-primary:hover { background: var(--color-primary-dark); }
        .btn-sm { padding: 6px 12px; font-size: 0.8rem; }
        .btn-icon {
            width: 32px; height: 32px;
            padding: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--bg-hover);
            border-radius: 6px;
        }
        .btn-icon:hover { background: var(--color-primary); }
        .btn-icon svg { width: 16px; height: 16px; }
        
        .table-loading, .table-empty {
            padding: 60px 20px;
            text-align: center;
            color: var(--text-muted);
        }
        .table-loading .spinner {
            width: 40px; height: 40px;
            border: 3px solid var(--border-color);
            border-top-color: var(--color-primary);
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin: 0 auto 16px;
        }
        @keyframes spin { to { transform: rotate(360deg); } }
        
        .pagination {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 20px;
            border-top: 1px solid var(--border-color);
        }
        .pagination-info { font-size: 0.85rem; color: var(--text-muted); }
        .pagination-btns { display: flex; gap: 8px; }
        .pagination-btns button {
            padding: 6px 12px;
            background: var(--bg-hover);
            border: none;
            border-radius: 6px;
            color: var(--text-secondary);
            cursor: pointer;
        }
        .pagination-btns button:hover { background: var(--color-primary); color: white; }
        .pagination-btns button:disabled { opacity: 0.5; cursor: not-allowed; }
        
        /* Filter Bar */
        .filter-bar {
            display: flex;
            gap: 12px;
            padding: 16px 20px;
            background: var(--bg-secondary);
            border-bottom: 1px solid var(--border-color);
            flex-wrap: wrap;
        }
        .filter-bar select, .filter-bar input[type="date"] {
            padding: 8px 12px;
            background: var(--bg-hover);
            border: 1px solid var(--border-color);
            border-radius: 6px;
            color: var(--text-primary);
            font-size: 0.85rem;
        }
        .filter-bar select:focus, .filter-bar input:focus {
            outline: none;
            border-color: var(--color-primary);
        }
        
        /* Reports Section */
        .report-cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
            padding: 20px;
        }
        .report-card {
            background: var(--bg-card);
            border-radius: 12px;
            padding: 24px;
            border: 1px solid var(--border-color);
            cursor: pointer;
            transition: all 0.2s;
        }
        .report-card:hover {
            border-color: var(--color-primary);
            transform: translateY(-2px);
        }
        .report-card h3 {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 8px;
        }
        .report-card h3 svg { width: 24px; height: 24px; color: var(--color-primary); }
        .report-card p { font-size: 0.85rem; color: var(--text-muted); }
    </style>
</head>
<body class="dashboard-page">
    <!-- Sidebar Navigation -->
    <nav class="sidebar">
        <div class="sidebar-header">
            <div class="logo">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                </svg>
            </div>
            <span class="logo-text">Security System</span>
        </div>
        
        <div class="nav-section">
            <a href="#" class="nav-item active" data-section="dashboard" onclick="showSection('dashboard'); return false;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="3" width="7" height="9"/>
                    <rect x="14" y="3" width="7" height="5"/>
                    <rect x="14" y="12" width="7" height="9"/>
                    <rect x="3" y="16" width="7" height="5"/>
                </svg>
                <span>Dashboard</span>
            </a>
            <a href="#" class="nav-item" data-section="students" onclick="showSection('students'); return false;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                    <circle cx="9" cy="7" r="4"/>
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                    <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
                <span>Students</span>
            </a>
            <a href="#" class="nav-item" data-section="logs" onclick="showSection('logs'); return false;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                    <polyline points="14 2 14 8 20 8"/>
                    <line x1="16" y1="13" x2="8" y2="13"/>
                    <line x1="16" y1="17" x2="8" y2="17"/>
                </svg>
                <span>Entry/Exit Logs</span>
            </a>
            <a href="#" class="nav-item" data-section="reports" onclick="showSection('reports'); return false;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="20" x2="18" y2="10"/>
                    <line x1="12" y1="20" x2="12" y2="4"/>
                    <line x1="6" y1="20" x2="6" y2="14"/>
                </svg>
                <span>Reports</span>
            </a>
            <a href="#" class="nav-item" data-section="users" onclick="showSection('users'); return false;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                    <circle cx="12" cy="7" r="4"/>
                </svg>
                <span>Users</span>
            </a>
        </div>
        
        <div class="sidebar-footer">
            <div class="user-info">
                <div class="user-avatar"><%= user.full_name.charAt(0) %></div>
                <div class="user-details">
                    <span class="user-name"><%= user.full_name %></span>
                    <span class="user-role"><%= user.role.toUpperCase() %></span>
                </div>
            </div>
            <a href="/logout" class="logout-link">Logout</a>
        </div>
    </nav>
    
    <!-- Main Content -->
    <main class="main-content">
        <!-- Header -->
        <header class="content-header">
            <div class="header-title">
                <h1 id="pageTitle">Admin Dashboard</h1>
                <p class="header-date" id="currentDate"></p>
            </div>
            <div class="header-actions">
                <div class="alert-bell" id="alertBell" onclick="showSection('dashboard'); return false;" style="cursor:pointer;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                        <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                    </svg>
                    <span class="alert-count" id="alertCount"><%= pendingAlerts.length %></span>
                </div>
            </div>
        </header>
        
        <!-- DASHBOARD SECTION -->
        <div class="section-content active" id="section-dashboard">
            <!-- Stats Cards -->
            <section class="stats-grid">
                <div class="stat-card">
                    <div class="stat-icon entries">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
                            <polyline points="10 17 15 12 10 7"/>
                            <line x1="15" y1="12" x2="3" y2="12"/>
                        </svg>
                    </div>
                    <div class="stat-content">
                        <span class="stat-value" id="statEntries"><%= stats.total_entries || 0 %></span>
                        <span class="stat-label">Entries Today</span>
                    </div>
                </div>
                
                <div class="stat-card">
                    <div class="stat-icon exits">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                            <polyline points="16 17 21 12 16 7"/>
                            <line x1="21" y1="12" x2="9" y2="12"/>
                        </svg>
                    </div>
                    <div class="stat-content">
                        <span class="stat-value" id="statExits"><%= stats.total_exits || 0 %></span>
                        <span class="stat-label">Exits Today</span>
                    </div>
                </div>
                
                <div class="stat-card warning">
                    <div class="stat-icon roaming">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"/>
                            <line x1="12" y1="8" x2="12" y2="12"/>
                            <line x1="12" y1="16" x2="12.01" y2="16"/>
                        </svg>
                    </div>
                    <div class="stat-content">
                        <span class="stat-value" id="statRoaming"><%= stats.roaming_incidents || 0 %></span>
                        <span class="stat-label">Roaming Detected</span>
                    </div>
                </div>
                
                <div class="stat-card">
                    <div class="stat-icon students">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                            <circle cx="9" cy="7" r="4"/>
                        </svg>
                    </div>
                    <div class="stat-content">
                        <span class="stat-value" id="statStudents"><%= stats.unique_students || 0 %></span>
                        <span class="stat-label">Unique Students</span>
                    </div>
                </div>
            </section>
            
            <!-- Main Grid -->
            <div class="dashboard-grid">
                <!-- Live Feed -->
                <section class="card live-feed-card">
                    <div class="card-header">
                        <h2>Live Activity Feed</h2>
                        <span class="refresh-indicator" id="refreshIndicator">
                            <span class="pulse"></span>
                            Live
                        </span>
                    </div>
                    <div class="card-content">
                        <div class="activity-list" id="activityList">
                            <% if (recentLogs && recentLogs.length > 0) { %>
                                <% recentLogs.slice(0, 20).forEach(log => { %>
                                    <div class="activity-item <%= log.event_type %> <%= log.is_allowed ? '' : 'denied' %>">
                                        <div class="activity-icon">
                                            <% if (log.event_type === 'entry') { %>
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                    <polyline points="10 17 15 12 10 7"/>
                                                </svg>
                                            <% } else if (log.event_type === 'exit') { %>
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                    <polyline points="14 7 9 12 14 17"/>
                                                </svg>
                                            <% } else { %>
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                    <circle cx="12" cy="12" r="10"/>
                                                    <line x1="12" y1="8" x2="12" y2="12"/>
                                                </svg>
                                            <% } %>
                                        </div>
                                        <div class="activity-details">
                                            <span class="activity-name"><%= log.full_name %></span>
                                            <span class="activity-info"><%= log.roll_number %> • <%= log.department_name || log.department_code || '' %></span>
                                        </div>
                                        <div class="activity-meta">
                                            <span class="activity-type"><%= log.event_type.toUpperCase() %></span>
                                            <span class="activity-time"><%= new Date(log.event_timestamp).toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit' }) %></span>
                                        </div>
                                    </div>
                                <% }) %>
                            <% } else { %>
                                <div class="empty-state">
                                    <p>No activity yet today</p>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </section>
                
                <!-- Alerts Panel -->
                <section class="card alerts-card">
                    <div class="card-header">
                        <h2>Pending Alerts</h2>
                        <span class="alert-badge"><%= pendingAlerts.length %></span>
                    </div>
                    <div class="card-content">
                        <div class="alerts-list" id="alertsList">
                            <% if (pendingAlerts && pendingAlerts.length > 0) { %>
                                <% pendingAlerts.slice(0, 10).forEach(function(alertItem) { %>
                                    <div class="alert-item priority-<%= alertItem.priority %>" data-id="<%= alertItem.id %>">
                                        <div class="alert-priority"></div>
                                        <div class="alert-content">
                                            <h4><%= alertItem.title || alertItem.alert_type %></h4>
                                            <p><%= alertItem.message %></p>
                                            <span class="alert-time"><%= alertItem.created_at ? new Date(alertItem.created_at).toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit' }) : '' %></span>
                                        </div>
                                        <div class="alert-actions">
                                            <button class="btn-acknowledge" onclick="acknowledgeAlert('<%= alertItem.id %>')">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                    <polyline points="20 6 9 17 4 12"/>
                                                </svg>
                                            </button>
                                        </div>
                                    </div>
                                <% }); %>
                            <% } else { %>
                                <div class="empty-state">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                                        <polyline points="22 4 12 14.01 9 11.01"/>
                                    </svg>
                                    <p>No pending alerts</p>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </section>
                
                <!-- Department Summary -->
                <section class="card department-card">
                    <div class="card-header">
                        <h2>Department Summary</h2>
                    </div>
                    <div class="card-content">
                        <div class="department-list" id="departmentList">
                            <% if (departments && departments.length > 0) { %>
                                <% departments.forEach(dept => { %>
                                    <div class="department-row">
                                        <span class="dept-code"><%= dept.code %></span>
                                        <span class="dept-name"><%= dept.name %></span>
                                        <span class="dept-count">--</span>
                                    </div>
                                <% }) %>
                            <% } else { %>
                                <div class="empty-state"><p>No departments</p></div>
                            <% } %>
                        </div>
                    </div>
                </section>
            </div>
        </div>
        
        <!-- STUDENTS SECTION -->
        <div class="section-content" id="section-students">
            <div class="data-table-wrapper">
                <div class="table-header">
                    <h2>All Students</h2>
                    <div class="search-box">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="11" cy="11" r="8"/>
                            <path d="m21 21-4.35-4.35"/>
                        </svg>
                        <input type="text" id="studentSearch" placeholder="Search by name or roll..." onkeyup="searchStudents()">
                    </div>
                </div>
                <div class="filter-bar">
                    <select id="deptFilter" onchange="loadStudents()">
                        <option value="">All Departments</option>
                        <% if (departments) departments.forEach(d => { %>
                            <option value="<%= d.code %>"><%= d.code %></option>
                        <% }) %>
                    </select>
                    <select id="yearFilter" onchange="loadStudents()">
                        <option value="">All Years</option>
                        <option value="1">1st Year</option>
                        <option value="2">2nd Year</option>
                        <option value="3">3rd Year</option>
                        <option value="4">4th Year</option>
                    </select>
                </div>
                <div id="studentsTableContainer">
                    <div class="table-loading">
                        <div class="spinner"></div>
                        <p>Loading students...</p>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- LOGS SECTION -->
        <div class="section-content" id="section-logs">
            <div class="data-table-wrapper">
                <div class="table-header">
                    <h2>Entry/Exit Logs</h2>
                    <div class="search-box">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="11" cy="11" r="8"/>
                            <path d="m21 21-4.35-4.35"/>
                        </svg>
                        <input type="text" id="logSearch" placeholder="Search by roll number..." onkeyup="searchLogs()">
                    </div>
                </div>
                <div class="filter-bar">
                    <input type="date" id="logDate" onchange="loadLogs()">
                    <select id="logType" onchange="loadLogs()">
                        <option value="">All Types</option>
                        <option value="entry">Entry</option>
                        <option value="exit">Exit</option>
                        <option value="roaming">Roaming</option>
                    </select>
                    <select id="logDept" onchange="loadLogs()">
                        <option value="">All Departments</option>
                        <% if (departments) departments.forEach(d => { %>
                            <option value="<%= d.code %>"><%= d.code %></option>
                        <% }) %>
                    </select>
                </div>
                <div id="logsTableContainer">
                    <div class="table-loading">
                        <div class="spinner"></div>
                        <p>Loading logs...</p>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- REPORTS SECTION -->
        <div class="section-content" id="section-reports">
            <div class="report-cards">
                <div class="report-card" onclick="generateReport('daily')">
                    <h3>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="4" width="18" height="18" rx="2"/>
                            <line x1="16" y1="2" x2="16" y2="6"/>
                            <line x1="8" y1="2" x2="8" y2="6"/>
                            <line x1="3" y1="10" x2="21" y2="10"/>
                        </svg>
                        Daily Report
                    </h3>
                    <p>View today's complete entry/exit summary with department breakdown</p>
                </div>
                <div class="report-card" onclick="generateReport('attendance')">
                    <h3>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                            <circle cx="9" cy="7" r="4"/>
                            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                        </svg>
                        Attendance Report
                    </h3>
                    <p>Student attendance tracking across departments</p>
                </div>
                <div class="report-card" onclick="generateReport('roaming')">
                    <h3>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"/>
                            <line x1="12" y1="8" x2="12" y2="12"/>
                            <line x1="12" y1="16" x2="12.01" y2="16"/>
                        </svg>
                        Roaming Incidents
                    </h3>
                    <p>List of students detected roaming during class hours</p>
                </div>
                <div class="report-card" onclick="generateReport('export')">
                    <h3>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                            <polyline points="7 10 12 15 17 10"/>
                            <line x1="12" y1="15" x2="12" y2="3"/>
                        </svg>
                        Export Data
                    </h3>
                    <p>Download logs as CSV or Excel file</p>
                </div>
            </div>
            <div id="reportOutput" style="padding: 20px;"></div>
        </div>
        
        <!-- USERS SECTION -->
        <div class="section-content" id="section-users">
            <div class="data-table-wrapper">
                <div class="table-header">
                    <h2>System Users</h2>
                    <button class="btn btn-primary" onclick="showAddUserModal()">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px;height:16px;margin-right:6px;">
                            <line x1="12" y1="5" x2="12" y2="19"/>
                            <line x1="5" y1="12" x2="19" y2="12"/>
                        </svg>
                        Add User
                    </button>
                </div>
                <div id="usersTableContainer">
                    <div class="table-loading">
                        <div class="spinner"></div>
                        <p>Loading users...</p>
                    </div>
                </div>
            </div>
        </div>
    </main>
    
    <script src="/js/dashboard.js"></script>
    <script>
        // Current data state
        let studentsData = [];
        let logsData = [];
        let usersData = [];
        
        // Set current date
        document.getElementById('currentDate').textContent = new Date().toLocaleDateString('en-IN', {
            weekday: 'long', year: 'numeric', month: 'long', day: 'numeric'
        });
        document.getElementById('logDate').valueAsDate = new Date();
        
        // Section Navigation
        window.showSection = function(section) {
            console.log('[Admin] showSection called:', section);
            
            // Update nav items
            document.querySelectorAll('.nav-item').forEach(item => {
                item.classList.remove('active');
                if (item.dataset.section === section) item.classList.add('active');
            });
            
            // Show/hide sections
            document.querySelectorAll('.section-content').forEach(el => {
                el.classList.remove('active');
            });
            const sectionEl = document.getElementById('section-' + section);
            console.log('[Admin] Section element:', sectionEl ? 'found' : 'NOT FOUND');
            if (sectionEl) sectionEl.classList.add('active');
            
            // Update title
            const titles = {
                dashboard: 'Admin Dashboard',
                students: 'Students Management',
                logs: 'Entry/Exit Logs',
                reports: 'Reports',
                users: 'User Management'
            };
            document.getElementById('pageTitle').textContent = titles[section] || 'Admin Dashboard';
            
            // Load data for section
            if (section === 'students') loadStudents();
            if (section === 'logs') loadLogs();
            if (section === 'users') loadUsers();
        };
        
        // Load Students
        async function loadStudents() {
            const container = document.getElementById('studentsTableContainer');
            container.innerHTML = '<div class="table-loading"><div class="spinner"></div><p>Loading students...</p></div>';
            
            try {
                const dept = document.getElementById('deptFilter').value;
                const year = document.getElementById('yearFilter').value;
                let url = '/api/students?limit=1000';
                if (dept) url += '&department=' + dept;
                if (year) url += '&year=' + year;
                
                const res = await fetch(url);
                const data = await res.json();
                studentsData = data.students || data || [];
                
                if (!studentsData.length) {
                    container.innerHTML = '<div class="table-empty"><p>No students found</p></div>';
                    return;
                }
                
                container.innerHTML = `
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Roll Number</th>
                                <th>Name</th>
                                <th>Department</th>
                                <th>Year</th>
                                <th>Phone</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            ${studentsData.map(s => `
                                <tr>
                                    <td><strong>${s.roll_number}</strong></td>
                                    <td>${s.full_name}</td>
                                    <td>${s.department_code || s.department || '--'}</td>
                                    <td>${s.year_of_study || s.year || '--'}</td>
                                    <td>${s.phone || '--'}</td>
                                    <td><span class="badge ${s.is_active !== false ? 'badge-success' : 'badge-danger'}">${s.is_active !== false ? 'Active' : 'Inactive'}</span></td>
                                </tr>
                            `).join('')}
                        </tbody>
                    </table>
                    <div class="pagination">
                        <span class="pagination-info">Showing ${studentsData.length} students</span>
                    </div>
                `;
            } catch (err) {
                console.error('Load students error:', err);
                container.innerHTML = '<div class="table-empty"><p>Error loading students</p></div>';
            }
        }
        
        function searchStudents() {
            const query = document.getElementById('studentSearch').value.toLowerCase();
            const rows = document.querySelectorAll('#studentsTableContainer tbody tr');
            rows.forEach(row => {
                const text = row.textContent.toLowerCase();
                row.style.display = text.includes(query) ? '' : 'none';
            });
        }
        
        // Load Logs
        async function loadLogs() {
            const container = document.getElementById('logsTableContainer');
            container.innerHTML = '<div class="table-loading"><div class="spinner"></div><p>Loading logs...</p></div>';
            
            try {
                const date = document.getElementById('logDate').value;
                const type = document.getElementById('logType').value;
                const dept = document.getElementById('logDept').value;
                
                const res = await fetch('/api/dashboard/live?limit=500');
                const data = await res.json();
                logsData = data.logs || [];
                
                if (!logsData.length) {
                    container.innerHTML = '<div class="table-empty"><p>No logs found for selected filters</p></div>';
                    return;
                }
                
                // Filter by type if selected
                let filtered = logsData;
                if (type) filtered = filtered.filter(l => l.event_type === type);
                if (dept) filtered = filtered.filter(l => (l.department || l.department_code) === dept);
                
                container.innerHTML = `
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Time</th>
                                <th>Roll Number</th>
                                <th>Name</th>
                                <th>Department</th>
                                <th>Type</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            ${filtered.map(l => `
                                <tr>
                                    <td>${new Date(l.timestamp || l.event_timestamp).toLocaleTimeString('en-IN', {hour:'2-digit', minute:'2-digit'})}</td>
                                    <td><strong>${l.roll_number}</strong></td>
                                    <td>${l.student_name || l.full_name || '--'}</td>
                                    <td>${l.department || l.department_code || '--'}</td>
                                    <td><span class="badge ${l.event_type === 'entry' ? 'badge-success' : l.event_type === 'exit' ? 'badge-info' : 'badge-warning'}">${(l.event_type || '').toUpperCase()}</span></td>
                                    <td><span class="badge ${l.is_allowed ? 'badge-success' : 'badge-danger'}">${l.is_allowed ? 'Allowed' : 'Denied'}</span></td>
                                </tr>
                            `).join('')}
                        </tbody>
                    </table>
                    <div class="pagination">
                        <span class="pagination-info">Showing ${filtered.length} logs</span>
                    </div>
                `;
            } catch (err) {
                console.error('Load logs error:', err);
                container.innerHTML = '<div class="table-empty"><p>Error loading logs</p></div>';
            }
        }
        
        function searchLogs() {
            const query = document.getElementById('logSearch').value.toLowerCase();
            const rows = document.querySelectorAll('#logsTableContainer tbody tr');
            rows.forEach(row => {
                const text = row.textContent.toLowerCase();
                row.style.display = text.includes(query) ? '' : 'none';
            });
        }
        
        // Load Users
        async function loadUsers() {
            const container = document.getElementById('usersTableContainer');
            container.innerHTML = '<div class="table-loading"><div class="spinner"></div><p>Loading users...</p></div>';
            
            try {
                const res = await fetch('/api/users');
                const data = await res.json();
                usersData = data.users || data || [];
                
                if (!usersData.length) {
                    container.innerHTML = '<div class="table-empty"><p>No users found</p></div>';
                    return;
                }
                
                container.innerHTML = `
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Username</th>
                                <th>Full Name</th>
                                <th>Role</th>
                                <th>Department</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            ${usersData.map(u => `
                                <tr>
                                    <td><strong>${u.username}</strong></td>
                                    <td>${u.full_name}</td>
                                    <td><span class="badge badge-info">${(u.role || '').toUpperCase()}</span></td>
                                    <td>${u.department_name || u.hostel_name || '--'}</td>
                                    <td><span class="badge ${u.is_active !== false ? 'badge-success' : 'badge-danger'}">${u.is_active !== false ? 'Active' : 'Inactive'}</span></td>
                                </tr>
                            `).join('')}
                        </tbody>
                    </table>
                `;
            } catch (err) {
                console.error('Load users error:', err);
                container.innerHTML = '<div class="table-empty"><p>Error loading users. API may not be available.</p></div>';
            }
        }
        
        // Generate Report
        async function generateReport(type) {
            const output = document.getElementById('reportOutput');
            output.innerHTML = '<div class="table-loading"><div class="spinner"></div><p>Generating report...</p></div>';
            
            try {
                const res = await fetch('/api/reports/' + type);
                const data = await res.json();
                
                if (type === 'daily') {
                    output.innerHTML = `
                        <div class="data-table-wrapper">
                            <div class="table-header"><h2>Daily Report - ${new Date().toLocaleDateString('en-IN')}</h2></div>
                            <div style="padding:20px;">
                                <p><strong>Total Entries:</strong> ${data.total_entries || 0}</p>
                                <p><strong>Total Exits:</strong> ${data.total_exits || 0}</p>
                                <p><strong>Unique Students:</strong> ${data.unique_students || 0}</p>
                                <p><strong>Roaming Incidents:</strong> ${data.roaming_incidents || 0}</p>
                            </div>
                        </div>
                    `;
                } else if (type === 'export') {
                    window.open('/api/reports/export?format=csv', '_blank');
                    output.innerHTML = '<p style="color: #10b981;">Download started...</p>';
                } else {
                    output.innerHTML = `<pre style="background:#1e293b;padding:20px;border-radius:8px;overflow:auto;">${JSON.stringify(data, null, 2)}</pre>`;
                }
            } catch (err) {
                console.error('Report error:', err);
                output.innerHTML = '<p style="color:#ef4444;">Error generating report. The API endpoint may not exist.</p>';
            }
        }
        
        function showAddUserModal() {
            alert('Add User functionality - Coming soon!\n\nTo add users, use the database directly or create an API endpoint.');
        }
        
        // Start auto-refresh for dashboard
        startDashboardRefresh();
    </script>
</body>
</html>
