<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body class="dashboard-page principal-dashboard">
    <!-- Sidebar Navigation -->
    <nav class="sidebar principal-sidebar">
        <div class="sidebar-header">
            <div class="logo">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                </svg>
            </div>
            <span class="logo-text">Security System</span>
        </div>
        
        <div class="nav-section">
            <a href="/dashboard/principal" class="nav-item active">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="3" width="7" height="9"/>
                    <rect x="14" y="3" width="7" height="5"/>
                    <rect x="14" y="12" width="7" height="9"/>
                    <rect x="3" y="16" width="7" height="5"/>
                </svg>
                <span>Overview</span>
            </a>
            <a href="#" class="nav-item" onclick="showSection('escalations')">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                    <line x1="12" y1="9" x2="12" y2="13"/>
                    <line x1="12" y1="17" x2="12.01" y2="17"/>
                </svg>
                <span>Escalations</span>
                <% if (escalatedAlerts && escalatedAlerts.length > 0) { %>
                    <span class="nav-badge danger"><%= escalatedAlerts.length %></span>
                <% } %>
            </a>
            <a href="#" class="nav-item" onclick="showSection('departments')">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="2" y="7" width="20" height="14" rx="2" ry="2"/>
                    <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
                </svg>
                <span>Departments</span>
            </a>
            <a href="#" class="nav-item" onclick="showSection('hostels')">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                    <polyline points="9 22 9 12 15 12 15 22"/>
                </svg>
                <span>Hostels</span>
            </a>
            <a href="/reports" class="nav-item">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                    <polyline points="14 2 14 8 20 8"/>
                    <line x1="16" y1="13" x2="8" y2="13"/>
                    <line x1="16" y1="17" x2="8" y2="17"/>
                </svg>
                <span>Reports</span>
            </a>
        </div>
        
        <div class="sidebar-footer">
            <div class="user-info">
                <div class="user-avatar"><%= user.full_name.charAt(0) %></div>
                <div class="user-details">
                    <span class="user-name"><%= user.full_name %></span>
                    <span class="user-role">Principal</span>
                </div>
            </div>
            <a href="/logout" class="logout-link">Logout</a>
        </div>
    </nav>
    
    <!-- Main Content -->
    <main class="main-content">
        <!-- Header -->
        <header class="content-header">
            <div class="header-title">
                <h1>Principal Dashboard</h1>
                <p class="header-subtitle"><%= new Date().toLocaleDateString('en-IN', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></p>
            </div>
            <div class="header-actions">
                <div class="alert-bell pulse-alert" id="alertBell" onclick="showAlerts()">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                        <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                    </svg>
                    <span class="alert-count" id="alertCount"><%= unreadAlertCount %></span>
                </div>
            </div>
        </header>
        
        <!-- Stats Cards Row 1 -->
        <section class="stats-grid principal-stats">
            <div class="stat-card large">
                <div class="stat-icon total">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                        <circle cx="9" cy="7" r="4"/>
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                        <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                    </svg>
                </div>
                <div class="stat-content">
                    <span class="stat-value"><%= stats.total_students || 0 %></span>
                    <span class="stat-label">Total Students</span>
                </div>
            </div>
            
            <div class="stat-card">
                <div class="stat-icon entries">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="10 17 15 12 10 7"/>
                    </svg>
                </div>
                <div class="stat-content">
                    <span class="stat-value"><%= stats.total_entries_today || 0 %></span>
                    <span class="stat-label">Entries Today</span>
                </div>
            </div>
            
            <div class="stat-card">
                <div class="stat-icon exits">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="14 7 9 12 14 17"/>
                    </svg>
                </div>
                <div class="stat-content">
                    <span class="stat-value"><%= stats.total_exits_today || 0 %></span>
                    <span class="stat-label">Exits Today</span>
                </div>
            </div>
            
            <div class="stat-card danger">
                <div class="stat-icon escalations">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                    </svg>
                </div>
                <div class="stat-content">
                    <span class="stat-value"><%= escalatedAlerts ? escalatedAlerts.length : 0 %></span>
                    <span class="stat-label">Escalations</span>
                </div>
            </div>
            
            <div class="stat-card warning">
                <div class="stat-icon roaming">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/>
                        <line x1="12" y1="8" x2="12" y2="12"/>
                    </svg>
                </div>
                <div class="stat-content">
                    <span class="stat-value"><%= stats.total_roaming_today || 0 %></span>
                    <span class="stat-label">Roaming Cases</span>
                </div>
            </div>
            
            <div class="stat-card">
                <div class="stat-icon curfew">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/>
                        <polyline points="12 6 12 12 16 14"/>
                    </svg>
                </div>
                <div class="stat-content">
                    <span class="stat-value"><%= stats.curfew_violations_today || 0 %></span>
                    <span class="stat-label">Curfew Violations</span>
                </div>
            </div>
        </section>
        
        <!-- Main Grid -->
        <div class="dashboard-grid principal-grid">
            <!-- Escalated Alerts (Priority) -->
            <section class="card escalations-card priority-card">
                <div class="card-header">
                    <h2>Escalated Alerts</h2>
                    <span class="badge danger"><%= escalatedAlerts ? escalatedAlerts.length : 0 %> Active</span>
                </div>
                <div class="card-content">
                    <div class="escalations-list" id="escalationsList">
                        <% if (escalatedAlerts && escalatedAlerts.length > 0) { %>
                            <% escalatedAlerts.forEach(function(alertItem) { %>
                                <div class="escalation-item priority-<%= alertItem.priority %>" data-id="<%= alertItem.id %>">
                                    <div class="escalation-header">
                                        <span class="escalation-type"><%= alertItem.alert_type ? alertItem.alert_type.replace(/_/g, ' ').toUpperCase() : 'ALERT' %></span>
                                        <span class="escalation-priority priority-<%= alertItem.priority %>"><%= alertItem.priority %></span>
                                    </div>
                                    <div class="escalation-content">
                                        <p><%= alertItem.message %></p>
                                        <% if (alertItem.full_name) { %>
                                            <span class="escalation-student"><%= alertItem.full_name %> (<%= alertItem.roll_number %>)</span>
                                        <% } %>
                                    </div>
                                    <div class="escalation-meta">
                                        <span class="escalation-time"><%= alertItem.created_at ? new Date(alertItem.created_at).toLocaleString('en-IN') : '' %></span>
                                        <% if (alertItem.department) { %>
                                            <span class="escalation-dept"><%= alertItem.department %></span>
                                        <% } %>
                                    </div>
                                    <div class="escalation-actions">
                                        <button class="btn-acknowledge" onclick="acknowledgeAlert('<%= alertItem.id %>')">Acknowledge</button>
                                    </div>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <div class="empty-state success">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                                    <polyline points="22 4 12 14.01 9 11.01"/>
                                </svg>
                                <p>No escalated alerts</p>
                            </div>
                        <% } %>
                    </div>
                </div>
            </section>
            
            <!-- Department Summary -->
            <section class="card departments-card">
                <div class="card-header">
                    <h2>Department Summary</h2>
                </div>
                <div class="card-content">
                    <div class="departments-grid">
                        <% if (departmentStats && departmentStats.length > 0) { %>
                            <% departmentStats.forEach(dept => { %>
                                <div class="dept-card">
                                    <h3><%= dept.department %></h3>
                                    <div class="dept-stats">
                                        <div class="dept-stat">
                                            <span class="dept-value"><%= dept.student_count || 0 %></span>
                                            <span class="dept-label">Students</span>
                                        </div>
                                        <div class="dept-stat">
                                            <span class="dept-value"><%= dept.entries_today || 0 %></span>
                                            <span class="dept-label">Entries</span>
                                        </div>
                                        <div class="dept-stat danger">
                                            <span class="dept-value"><%= dept.roaming_today || 0 %></span>
                                            <span class="dept-label">Roaming</span>
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <div class="empty-state">
                                <p>No department data</p>
                            </div>
                        <% } %>
                    </div>
                </div>
            </section>
            
            <!-- Hostel Summary -->
            <section class="card hostels-card">
                <div class="card-header">
                    <h2>Hostel Summary</h2>
                </div>
                <div class="card-content">
                    <div class="hostels-grid">
                        <% if (hostelStats && hostelStats.length > 0) { %>
                            <% hostelStats.forEach(hostel => { %>
                                <div class="hostel-card">
                                    <h3><%= hostel.hostel_name %></h3>
                                    <div class="hostel-stats">
                                        <div class="hostel-stat">
                                            <span class="hostel-value"><%= hostel.total_residents || 0 %></span>
                                            <span class="hostel-label">Residents</span>
                                        </div>
                                        <div class="hostel-stat success">
                                            <span class="hostel-value"><%= hostel.inside_count || 0 %></span>
                                            <span class="hostel-label">Inside</span>
                                        </div>
                                        <div class="hostel-stat warning">
                                            <span class="hostel-value"><%= hostel.outside_count || 0 %></span>
                                            <span class="hostel-label">Outside</span>
                                        </div>
                                        <div class="hostel-stat danger">
                                            <span class="hostel-value"><%= hostel.violations_today || 0 %></span>
                                            <span class="hostel-label">Violations</span>
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <div class="empty-state">
                                <p>No hostel data</p>
                            </div>
                        <% } %>
                    </div>
                </div>
            </section>
            
            <!-- Recent Activity Feed -->
            <section class="card activity-card">
                <div class="card-header">
                    <h2>Campus Activity</h2>
                    <span class="refresh-indicator">
                        <span class="pulse"></span>
                        Live
                    </span>
                </div>
                <div class="card-content">
                    <div class="activity-list" id="activityList">
                        <% if (recentLogs && recentLogs.length > 0) { %>
                            <% recentLogs.slice(0, 20).forEach(log => { %>
                                <div class="activity-item <%= log.event_type %> <%= log.is_allowed ? '' : 'denied' %>">
                                    <div class="activity-icon">
                                        <% if (log.event_type === 'entry') { %>
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <polyline points="10 17 15 12 10 7"/>
                                            </svg>
                                        <% } else { %>
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <polyline points="14 7 9 12 14 17"/>
                                            </svg>
                                        <% } %>
                                    </div>
                                    <div class="activity-details">
                                        <span class="activity-name"><%= log.full_name %></span>
                                        <span class="activity-info"><%= log.roll_number %> • <%= log.department %></span>
                                    </div>
                                    <div class="activity-meta">
                                        <span class="activity-type"><%= log.event_type.toUpperCase() %></span>
                                        <span class="activity-time"><%= new Date(log.event_timestamp).toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit' }) %></span>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <div class="empty-state">
                                <p>No activity yet today</p>
                            </div>
                        <% } %>
                    </div>
                </div>
            </section>
        </div>
    </main>
    
    <script src="/js/dashboard.js"></script>
    <script>
        async function acknowledgeAlert(id) {
            try {
                const response = await fetch(`/api/alerts/${id}/acknowledge`, {
                    method: 'POST'
                });
                
                const data = await response.json();
                
                if (data.success) {
                    document.querySelector(`.escalation-item[data-id="${id}"]`).remove();
                    updateAlertCount();
                }
            } catch (error) {
                console.error('Error acknowledging:', error);
            }
        }
        
        // Start auto-refresh
        startDashboardRefresh();
    </script>
</body>
</html>
