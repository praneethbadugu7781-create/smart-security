<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Security Scanner</title>
    <meta name="theme-color" content="#0f172a">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- Html5-QRcode Library -->
    <script src="https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>
    
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body {
            font-family: 'Inter', -apple-system, sans-serif;
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
            color: #f8fafc;
            min-height: 100vh;
            overflow-x: hidden;
        }
        
        /* Header */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 16px 24px;
            background: rgba(15, 23, 42, 0.9);
            border-bottom: 1px solid rgba(255,255,255,0.1);
            position: sticky;
            top: 0;
            z-index: 100;
        }
        
        .header-left {
            display: flex;
            align-items: center;
            gap: 12px;
        }
        
        .logo {
            width: 44px;
            height: 44px;
            background: linear-gradient(135deg, #3b82f6, #1d4ed8);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .logo svg { width: 24px; height: 24px; color: white; }
        
        .header-title h1 {
            font-size: 1.1rem;
            font-weight: 700;
            letter-spacing: 0.05em;
        }
        
        .header-title span {
            font-size: 0.7rem;
            color: #3b82f6;
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }
        
        .header-right {
            display: flex;
            align-items: center;
            gap: 20px;
        }
        
        .clock {
            text-align: right;
        }
        
        .clock .time {
            font-size: 1.3rem;
            font-weight: 700;
            font-variant-numeric: tabular-nums;
        }
        
        .clock .date {
            font-size: 0.7rem;
            color: #94a3b8;
        }
        
        .logout {
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #334155;
            border-radius: 8px;
            color: #94a3b8;
            text-decoration: none;
            transition: all 0.2s;
        }
        
        .logout:hover {
            background: #ef4444;
            color: white;
        }
        
        .logout svg { width: 20px; height: 20px; }
        
        /* Main Layout */
        .main {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 24px;
            padding: 24px;
            max-width: 1400px;
            margin: 0 auto;
            min-height: calc(100vh - 80px);
        }
        
        @media (max-width: 900px) {
            .main {
                grid-template-columns: 1fr;
                padding: 16px;
                gap: 16px;
            }
        }
        
        /* Scanner Section */
        .scanner-section {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }
        
        .scanner-box {
            position: relative;
            background: #1e293b;
            border-radius: 20px;
            overflow: hidden;
            border: 1px solid rgba(255,255,255,0.1);
            aspect-ratio: 4/3;
            min-height: 350px;
        }
        
        #reader {
            width: 100%;
            height: 100%;
        }
        
        #reader video {
            width: 100% !important;
            height: 100% !important;
            object-fit: cover !important;
            border-radius: 20px;
        }
        
        /* Hide Html5Qrcode default elements */
        #reader__scan_region { border: none !important; }
        #reader__dashboard { display: none !important; }
        #reader img[alt="Info icon"] { display: none !important; }
        
        /* Scanner Overlay */
        .scanner-overlay {
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            pointer-events: none;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            z-index: 10;
        }
        
        .scan-frame {
            width: 260px;
            height: 150px;
            position: relative;
        }
        
        .scan-frame::before,
        .scan-frame::after,
        .scan-frame .corner1,
        .scan-frame .corner2 {
            content: '';
            position: absolute;
            width: 30px;
            height: 30px;
            border: 4px solid #3b82f6;
        }
        
        .scan-frame::before {
            top: 0; left: 0;
            border-right: none; border-bottom: none;
            border-radius: 8px 0 0 0;
        }
        
        .scan-frame::after {
            top: 0; right: 0;
            border-left: none; border-bottom: none;
            border-radius: 0 8px 0 0;
        }
        
        .scan-frame .corner1 {
            bottom: 0; left: 0;
            border-right: none; border-top: none;
            border-radius: 0 0 0 8px;
        }
        
        .scan-frame .corner2 {
            bottom: 0; right: 0;
            border-left: none; border-top: none;
            border-radius: 0 0 8px 0;
        }
        
        .scan-line {
            position: absolute;
            top: 0; left: 15px; right: 15px;
            height: 3px;
            background: linear-gradient(90deg, transparent, #3b82f6, transparent);
            box-shadow: 0 0 15px #3b82f6;
            animation: scanAnim 2s ease-in-out infinite;
        }
        
        @keyframes scanAnim {
            0%, 100% { top: 5px; opacity: 0.3; }
            50% { top: calc(100% - 8px); opacity: 1; }
        }
        
        .scan-hint {
            margin-top: 20px;
            font-size: 0.85rem;
            color: white;
            background: rgba(0,0,0,0.6);
            padding: 8px 16px;
            border-radius: 20px;
        }
        
        /* Status Bar */
        .status-bar {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            background: #1e293b;
            border-radius: 12px;
            border: 1px solid rgba(255,255,255,0.1);
        }
        
        .status-dot {
            width: 10px;
            height: 10px;
            background: #22c55e;
            border-radius: 50%;
            animation: pulse 2s ease infinite;
        }
        
        @keyframes pulse {
            0%, 100% { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.4); }
            50% { box-shadow: 0 0 0 8px rgba(34, 197, 94, 0); }
        }
        
        .status-bar span { color: #94a3b8; font-size: 0.85rem; }
        .status-bar strong { color: #f8fafc; }
        
        /* Result Section */
        .result-section {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }
        
        /* Result Card */
        .result-card {
            background: #1e293b;
            border-radius: 20px;
            padding: 32px;
            border: 2px solid transparent;
            display: none;
            flex-direction: column;
            align-items: center;
            animation: slideIn 0.3s ease;
        }
        
        @keyframes slideIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        .result-card.show { display: flex; }
        .result-card.success { border-color: #22c55e; box-shadow: 0 0 40px rgba(34, 197, 94, 0.2); }
        .result-card.denied { border-color: #ef4444; box-shadow: 0 0 40px rgba(239, 68, 68, 0.2); }
        .result-card.warning { border-color: #eab308; box-shadow: 0 0 40px rgba(234, 179, 8, 0.2); }
        
        .result-icon {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 16px;
        }
        
        .result-icon.success { background: rgba(34, 197, 94, 0.15); }
        .result-icon.denied { background: rgba(239, 68, 68, 0.15); }
        .result-icon svg { width: 40px; height: 40px; }
        .result-icon.success svg { color: #22c55e; }
        .result-icon.denied svg { color: #ef4444; }
        
        .result-status {
            font-size: 1.8rem;
            font-weight: 800;
            margin-bottom: 24px;
        }
        
        .result-status.success { color: #22c55e; }
        .result-status.denied { color: #ef4444; }
        
        .student-box {
            width: 100%;
            background: #334155;
            border-radius: 12px;
            padding: 16px;
            display: flex;
            align-items: center;
            gap: 16px;
            margin-bottom: 16px;
        }
        
        .student-avatar {
            width: 56px;
            height: 56px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            font-weight: 700;
            color: white;
        }
        
        .student-avatar.success { background: linear-gradient(135deg, #22c55e, #16a34a); }
        .student-avatar.denied { background: linear-gradient(135deg, #ef4444, #dc2626); }
        
        .student-details h3 {
            font-size: 1.1rem;
            font-weight: 600;
            margin-bottom: 4px;
        }
        
        .student-details .roll {
            font-size: 0.95rem;
            color: #3b82f6;
            font-weight: 600;
        }
        
        .student-details .meta {
            font-size: 0.8rem;
            color: #94a3b8;
        }
        
        .event-row {
            width: 100%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 12px;
        }
        
        .event-badge {
            padding: 6px 14px;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
        }
        
        .event-badge.entry { background: rgba(59, 130, 246, 0.15); color: #3b82f6; }
        .event-badge.exit { background: rgba(249, 115, 22, 0.15); color: #f97316; }
        .event-badge.roaming { background: rgba(239, 68, 68, 0.15); color: #ef4444; }
        
        .event-time {
            font-size: 0.85rem;
            color: #94a3b8;
        }
        
        .result-message {
            width: 100%;
            padding: 12px;
            background: #0f172a;
            border-radius: 8px;
            font-size: 0.85rem;
            text-align: center;
            color: #94a3b8;
        }
        
        /* Ready State */
        .ready-state {
            background: #1e293b;
            border-radius: 20px;
            padding: 48px 32px;
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            border: 1px solid rgba(255,255,255,0.1);
        }
        
        .ready-icon {
            width: 100px;
            height: 100px;
            position: relative;
            margin-bottom: 24px;
        }
        
        .ready-icon .pulse-ring {
            position: absolute;
            width: 100%;
            height: 100%;
            border: 2px solid #3b82f6;
            border-radius: 50%;
            animation: pulseRing 2s ease-out infinite;
        }
        
        @keyframes pulseRing {
            0% { transform: scale(0.8); opacity: 0.6; }
            100% { transform: scale(1.3); opacity: 0; }
        }
        
        .ready-icon .center {
            position: absolute;
            top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            width: 60px;
            height: 60px;
            background: #334155;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .ready-icon .center svg {
            width: 28px;
            height: 28px;
            color: #3b82f6;
        }
        
        .ready-state h2 {
            font-size: 1.4rem;
            margin-bottom: 8px;
        }
        
        .ready-state p {
            color: #94a3b8;
            font-size: 0.9rem;
        }
        
        /* Error State */
        .error-box {
            display: none;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: #1e293b;
            padding: 32px;
            text-align: center;
            z-index: 20;
        }
        
        .error-box.show { display: flex; }
        
        .error-box svg {
            width: 60px;
            height: 60px;
            color: #ef4444;
            margin-bottom: 16px;
        }
        
        .error-box p {
            color: #94a3b8;
            margin-bottom: 20px;
            max-width: 280px;
        }
        
        .retry-btn {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 12px 24px;
            background: #3b82f6;
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 0.9rem;
            font-weight: 600;
            cursor: pointer;
        }
        
        .retry-btn:hover { background: #2563eb; }
        .retry-btn svg { width: 18px; height: 18px; }
        
        /* Loading */
        .loading-box {
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: #1e293b;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            z-index: 15;
        }
        
        .loading-box.hide { display: none; }
        
        .spinner {
            width: 50px;
            height: 50px;
            border: 4px solid #334155;
            border-top-color: #3b82f6;
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin-bottom: 16px;
        }
        
        @keyframes spin { to { transform: rotate(360deg); } }
        
        .loading-box p { color: #94a3b8; }
        
        /* Recent Scans */
        .recent-scans {
            background: #1e293b;
            border-radius: 16px;
            overflow: hidden;
            border: 1px solid rgba(255,255,255,0.1);
            flex: 1;
            display: flex;
            flex-direction: column;
        }
        
        .recent-header {
            padding: 16px;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            font-size: 0.85rem;
            font-weight: 600;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }
        
        .recent-list {
            flex: 1;
            overflow-y: auto;
            padding: 8px;
            max-height: 300px;
        }
        
        .recent-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 12px;
            background: #334155;
            border-radius: 10px;
            margin-bottom: 6px;
            border-left: 3px solid transparent;
        }
        
        .recent-item.success { border-left-color: #22c55e; }
        .recent-item.denied { border-left-color: #ef4444; }
        
        .recent-item .dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
        }
        
        .recent-item.success .dot { background: #22c55e; }
        .recent-item.denied .dot { background: #ef4444; }
        
        .recent-item .info { flex: 1; }
        .recent-item .roll { font-size: 0.85rem; font-weight: 600; }
        .recent-item .name { font-size: 0.75rem; color: #94a3b8; }
        .recent-item .time { font-size: 0.7rem; color: #64748b; }
        
        .empty-msg {
            padding: 32px;
            text-align: center;
            color: #64748b;
            font-size: 0.85rem;
        }
    </style>
</head>
<body>
    <!-- Header -->
    <header class="header">
        <div class="header-left">
            <div class="logo">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                </svg>
            </div>
            <div class="header-title">
                <h1>SECURITY SCANNER</h1>
                <span>Main Gate</span>
            </div>
        </div>
        <div class="header-right">
            <div class="clock">
                <div class="time" id="clock-time">--:--:--</div>
                <div class="date" id="clock-date">---</div>
            </div>
            <a href="/logout" class="logout" title="Logout">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                    <polyline points="16 17 21 12 16 7"/>
                    <line x1="21" y1="12" x2="9" y2="12"/>
                </svg>
            </a>
        </div>
    </header>

    <!-- Main Content -->
    <main class="main">
        <!-- Scanner Section -->
        <section class="scanner-section">
            <div class="scanner-box">
                <!-- Reader Container -->
                <div id="reader"></div>
                
                <!-- Scanner Overlay -->
                <div class="scanner-overlay">
                    <div class="scan-frame">
                        <div class="corner1"></div>
                        <div class="corner2"></div>
                        <div class="scan-line"></div>
                    </div>
                    <p class="scan-hint">Position barcode within frame</p>
                </div>
                
                <!-- Loading -->
                <div class="loading-box" id="loading">
                    <div class="spinner"></div>
                    <p>Starting camera...</p>
                </div>
                
                <!-- Error -->
                <div class="error-box" id="error-box">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/>
                        <circle cx="12" cy="13" r="4"/>
                        <line x1="1" y1="1" x2="23" y2="23"/>
                    </svg>
                    <p id="error-msg">Camera access denied</p>
                    <button class="retry-btn" onclick="startScanner()">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="23 4 23 10 17 10"/>
                            <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>
                        </svg>
                        Try Again
                    </button>
                </div>
            </div>
            
            <div class="status-bar">
                <div class="status-dot"></div>
                <span>Scanner Active</span>
                <span style="margin-left: auto;">Scans: <strong id="scan-count">0</strong></span>
            </div>
        </section>

        <!-- Result Section -->
        <section class="result-section">
            <!-- Result Card (hidden) -->
            <div class="result-card" id="result-card">
                <div class="result-icon" id="result-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" id="result-svg"></svg>
                </div>
                <div class="result-status" id="result-status">ALLOWED</div>
                <div class="student-box">
                    <div class="student-avatar" id="student-avatar">P</div>
                    <div class="student-details">
                        <h3 id="student-name">Student Name</h3>
                        <p class="roll" id="student-roll">24H71A0544</p>
                        <p class="meta" id="student-meta">CSE • Year 3 • Sec A</p>
                    </div>
                </div>
                <div class="event-row">
                    <span class="event-badge" id="event-badge">ENTRY</span>
                    <span class="event-time" id="event-time">12:00:00 PM</span>
                </div>
                <div class="result-message" id="result-message"></div>
            </div>
            
            <!-- Ready State -->
            <div class="ready-state" id="ready-state">
                <div class="ready-icon">
                    <div class="pulse-ring"></div>
                    <div class="center">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="3" width="18" height="18" rx="2"/>
                            <line x1="7" y1="8" x2="17" y2="8"/>
                            <line x1="7" y1="12" x2="17" y2="12"/>
                            <line x1="7" y1="16" x2="13" y2="16"/>
                        </svg>
                    </div>
                </div>
                <h2>Ready to Scan</h2>
                <p>Point camera at student ID barcode</p>
            </div>
            
            <!-- Recent Scans -->
            <div class="recent-scans">
                <div class="recent-header">Recent Activity</div>
                <div class="recent-list" id="recent-list">
                    <div class="empty-msg">No scans yet</div>
                </div>
            </div>
        </section>
    </main>

    <script>
    (function() {
        'use strict';
        
        // State
        let scanner = null;
        let isProcessing = false;
        let lastScanTime = 0;
        let lastCode = '';
        let scanCount = 0;
        let recentScans = [];
        
        const COOLDOWN = 3000;
        
        // Initialize
        document.addEventListener('DOMContentLoaded', () => {
            updateClock();
            setInterval(updateClock, 1000);
            startScanner();
        });
        
        // Clock
        function updateClock() {
            const now = new Date();
            document.getElementById('clock-time').textContent = now.toLocaleTimeString('en-IN', {
                hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: true
            });
            document.getElementById('clock-date').textContent = now.toLocaleDateString('en-IN', {
                weekday: 'short', day: 'numeric', month: 'short'
            });
        }
        
        // Start Scanner
        window.startScanner = async function() {
            const loading = document.getElementById('loading');
            const errorBox = document.getElementById('error-box');
            
            loading.classList.remove('hide');
            errorBox.classList.remove('show');
            
            try {
                // Check library loaded
                if (typeof Html5Qrcode === 'undefined') {
                    throw new Error('Scanner library not loaded. Please refresh.');
                }
                
                // Stop existing
                if (scanner) {
                    try { await scanner.stop(); } catch(e) {}
                }
                
                // Create scanner
                scanner = new Html5Qrcode('reader', { verbose: false });
                
                // Start
                await scanner.start(
                    { facingMode: 'environment' },
                    {
                        fps: 10,
                        qrbox: { width: 250, height: 150 },
                        aspectRatio: 1.333
                    },
                    onScanSuccess,
                    () => {} // Ignore errors (no code found)
                );
                
                loading.classList.add('hide');
                console.log('Scanner started!');
                
            } catch (err) {
                console.error('Scanner error:', err);
                loading.classList.add('hide');
                document.getElementById('error-msg').textContent = getErrorMessage(err);
                errorBox.classList.add('show');
            }
        };
        
        function getErrorMessage(err) {
            if (err.name === 'NotAllowedError') {
                return 'Camera permission denied. Please allow camera access and try again.';
            } else if (err.name === 'NotFoundError') {
                return 'No camera found. Please connect a camera.';
            } else if (err.name === 'NotReadableError') {
                return 'Camera is in use by another app.';
            }
            return err.message || 'Unable to start camera.';
        }
        
        // On Scan Success
        async function onScanSuccess(code) {
            const now = Date.now();
            
            // Cooldown check
            if (isProcessing || now - lastScanTime < COOLDOWN) return;
            if (code === lastCode && now - lastScanTime < 5000) return;
            
            console.log('Scanned:', code);
            
            isProcessing = true;
            lastScanTime = now;
            lastCode = code;
            
            // Beep sound
            playSound('beep');
            
            try {
                const response = await fetch('/api/scan', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ roll_number: code })
                });
                
                const data = await response.json();
                console.log('API Response:', data);
                
                showResult(data);
                scanCount++;
                document.getElementById('scan-count').textContent = scanCount;
                
            } catch (err) {
                console.error('API Error:', err);
                showError('Connection failed. Please try again.');
            }
            
            // Reset after delay
            setTimeout(() => {
                isProcessing = false;
                hideResult();
            }, 4000);
        }
        
        // Show Result
        function showResult(data) {
            const card = document.getElementById('result-card');
            const readyState = document.getElementById('ready-state');
            
            const isAllowed = data.display?.status === 'ALLOWED';
            const status = data.display?.status || (data.success ? 'ALLOWED' : 'DENIED');
            const color = data.display?.color || (isAllowed ? 'green' : 'red');
            const message = data.display?.message || '';
            const student = data.student || {};
            const event = data.event || {};
            
            // Play sound
            playSound(isAllowed ? 'success' : 'denied');
            
            // Vibrate
            if (navigator.vibrate) {
                navigator.vibrate(isAllowed ? [100] : [100, 50, 100]);
            }
            
            // Update card
            card.className = 'result-card show ' + (color === 'green' ? 'success' : 'denied');
            
            const icon = document.getElementById('result-icon');
            const svg = document.getElementById('result-svg');
            icon.className = 'result-icon ' + (color === 'green' ? 'success' : 'denied');
            svg.innerHTML = color === 'green' 
                ? '<path d="M20 6L9 17l-5-5"/>'
                : '<path d="M18 6L6 18M6 6l12 12"/>';
            
            const statusEl = document.getElementById('result-status');
            statusEl.className = 'result-status ' + (color === 'green' ? 'success' : 'denied');
            statusEl.textContent = status;
            
            const avatar = document.getElementById('student-avatar');
            avatar.className = 'student-avatar ' + (color === 'green' ? 'success' : 'denied');
            avatar.textContent = (student.name || 'U')[0].toUpperCase();
            
            document.getElementById('student-name').textContent = student.name || 'Unknown Student';
            document.getElementById('student-roll').textContent = student.roll_number || code;
            document.getElementById('student-meta').textContent = 
                `${student.department || '---'} ${student.year ? '• Year ' + student.year : ''} ${student.section ? '• Sec ' + student.section : ''}`;
            
            const badge = document.getElementById('event-badge');
            badge.className = 'event-badge ' + (event.type || 'entry');
            badge.textContent = (event.type || 'SCAN').toUpperCase();
            
            document.getElementById('event-time').textContent = new Date().toLocaleTimeString('en-IN', {
                hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: true
            });
            
            const msgEl = document.getElementById('result-message');
            msgEl.textContent = message;
            msgEl.style.display = message ? 'block' : 'none';
            
            readyState.style.display = 'none';
            
            // Add to recent
            addRecent({
                roll: student.roll_number || code,
                name: student.name,
                status: status,
                time: new Date().toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit' })
            });
        }
        
        function showError(msg) {
            const card = document.getElementById('result-card');
            const readyState = document.getElementById('ready-state');
            
            card.className = 'result-card show denied';
            document.getElementById('result-icon').className = 'result-icon denied';
            document.getElementById('result-svg').innerHTML = '<circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>';
            document.getElementById('result-status').className = 'result-status denied';
            document.getElementById('result-status').textContent = 'ERROR';
            document.getElementById('result-message').textContent = msg;
            document.getElementById('result-message').style.display = 'block';
            readyState.style.display = 'none';
            
            playSound('denied');
        }
        
        function hideResult() {
            document.getElementById('result-card').classList.remove('show');
            document.getElementById('ready-state').style.display = 'flex';
        }
        
        // Recent Scans
        function addRecent(scan) {
            recentScans.unshift(scan);
            if (recentScans.length > 10) recentScans.pop();
            
            const list = document.getElementById('recent-list');
            list.innerHTML = recentScans.map(s => `
                <div class="recent-item ${s.status === 'ALLOWED' ? 'success' : 'denied'}">
                    <div class="dot"></div>
                    <div class="info">
                        <div class="roll">${s.roll}</div>
                        <div class="name">${s.name || 'Unknown'}</div>
                    </div>
                    <div class="time">${s.time}</div>
                </div>
            `).join('');
        }
        
        // Sound
        function playSound(type) {
            try {
                const ctx = new (window.AudioContext || window.webkitAudioContext)();
                const osc = ctx.createOscillator();
                const gain = ctx.createGain();
                osc.connect(gain);
                gain.connect(ctx.destination);
                gain.gain.value = 0.15;
                
                if (type === 'beep') {
                    osc.frequency.value = 1200;
                    osc.type = 'sine';
                    osc.start();
                    osc.stop(ctx.currentTime + 0.08);
                } else if (type === 'success') {
                    osc.frequency.value = 800;
                    osc.type = 'sine';
                    osc.start();
                    setTimeout(() => osc.frequency.value = 1200, 100);
                    osc.stop(ctx.currentTime + 0.2);
                } else {
                    osc.frequency.value = 300;
                    osc.type = 'square';
                    gain.gain.value = 0.1;
                    osc.start();
                    osc.stop(ctx.currentTime + 0.35);
                }
            } catch(e) {}
        }
    })();
    </script>
</body>
</html>
